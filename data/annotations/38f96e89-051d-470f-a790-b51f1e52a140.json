      "annotation": [
        {
          "text": "Tanta Indecencia\".  Composed by Guillermo Mundo of the Delegación del Norte",
          "bold": true
        },
        {
          "text": "\nYo no feliz vivir aquí"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Yo no feliz vivir aquí"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Yo lo pedí óyeme bien\nTanta indecencia"
        },
        {
          "type": "line-break",
