    {
      "start_time": 90,
      "end_time": 133,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "A singer sings in an African dialect. Most likely creole. \n\n"
            }
          ]
        }
      ],
      "tags": [],
      "uuid": "7a12f40b-be0f-4de8-ad4c-d529865bb2b6"
